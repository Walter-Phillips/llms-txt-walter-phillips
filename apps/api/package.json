{
  "name": "@profound-takehome/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787 --show-interactive-dev-session=false",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude \"**/*.live.test.ts\"",
    "test:toscrape:live": "vitest run src/crawler/toscrape.live.test.ts",
    "db:migrate:local": "wrangler d1 migrations apply llms_txt --local",
    "db:migrate:remote": "wrangler d1 migrations apply llms_txt --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@axiomhq/js": "^1.6.1",
    "@profound-takehome/db": "workspace:*",
    "@profound-takehome/shared": "workspace:*",
    "@sentry/cloudflare": "^10.57.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "pino": "^10.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "@profound-takehome/config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^50",
    "eslint-plugin-unicorn": "^55",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8",
    "vitest": "^2.1.0",
    "wrangler": "^4.100.0"
  }
}
