{
  "name": "@profound-takehome/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply llms_txt --local",
    "db:migrate:remote": "wrangler d1 migrations apply llms_txt --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@profound-takehome/db": "workspace:*",
    "@profound-takehome/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@eslint/js": "^9",
    "@profound-takehome/config": "workspace:*",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^50",
    "eslint-plugin-unicorn": "^55",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8",
    "vitest": "^2.1.0",
    "wrangler": "^3.95.0"
  }
}
