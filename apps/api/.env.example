# For wrangler dev. In production, set as a secret:
#   wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Optional observability. In production, set tokens/DSNs as secrets:
#   wrangler secret put SENTRY_DSN
#   wrangler secret put AXIOM_TOKEN
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0
AXIOM_TOKEN=xaat-xxxxxxxxxx
AXIOM_DATASET=llms-txt-prod
# AXIOM_EDGE_URL=https://your-region.edge.axiom.co
# AXIOM_ORG_ID=org_xxxxxxxxxx
