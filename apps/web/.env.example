# Wrangler dev defaults to 8787. Set to deployed Worker URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8787

# Set to 1 to run the UI against an in-memory mock API (no backend needed).
# The mock simulates a full crawl with live progress; submit a URL whose
# hostname contains "error" to demo the failure path.
NEXT_PUBLIC_API_MOCK=0

# Canonical public origin of the deployed site. Used for SEO metadata,
# sitemap.xml, robots.txt, and structured data. Must be set in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
